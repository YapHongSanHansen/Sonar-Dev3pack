# Copy to .env.local and fill in. For Vercel deploy: paste these into
# Vercel dashboard → Settings → Environment Variables.

# ElevenLabs — https://elevenlabs.io (free tier works)
ELEVENLABS_API_KEY=
# Voice ID from https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Solana network (devnet | mainnet-beta | testnet)
SOLANA_NETWORK=devnet

# Helius — Solana RPC + parsed-tx history (https://helius.dev)
HELIUS_API_KEY=

# Chainabuse — scam-report lookups (https://chainabuse.com)
# Free tier is 10 req/key/month. Use numbered slots to add as many keys as
# you have — the code auto-rotates to the next slot when one returns 429.
# Either format works (and you can mix them); duplicates are deduped.
CHAINABUSE_API_KEY_1=
CHAINABUSE_API_KEY_2=
CHAINABUSE_API_KEY_3=
# …add more as needed: CHAINABUSE_API_KEY_4, CHAINABUSE_API_KEY_5, etc.

# Optional comma-separated fallback (kept for back-compat with older setups):
# CHAINABUSE_API_KEY=key1,key2,key3

# WhoisXML — domain age lookups (https://whoisxmlapi.com)
WHOISXML_API_KEY=
