# Copy to .env and fill in. For Vercel deploy: paste these into Vercel
# dashboard → Settings → Environment Variables.

# Supabase (Settings → API in your Supabase dashboard)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ElevenLabs — https://elevenlabs.io (free tier works)
ELEVENLABS_API_KEY=
# Voice ID from https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Solana network (devnet | mainnet-beta | testnet)
SOLANA_NETWORK=devnet

# Helius — Solana RPC + parsed-tx history (https://helius.dev)
HELIUS_API_KEY=

# Chainabuse — scam-report lookups (https://chainabuse.com)
CHAINABUSE_API_KEY=

# WhoisXML — domain age lookups (https://whoisxmlapi.com)
WHOISXML_API_KEY=
